{
  "name": "ambientvrt",
  "version": "0.0.1",
  "description": "React Native capture adapter and the npm distribution wrapper for the AmbientVRT core binary.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bin": {
    "ambient": "bin/ambient.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "scripts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist vendor",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "postinstall": "node ./scripts/postinstall.js",
    "prepack": "npm run clean && npm run build",
    "test": "node --test ./test/wrapper.test.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.19.41",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
